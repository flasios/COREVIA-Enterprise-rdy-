{
  "name": "corevia",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development node infrastructure/scripts/run-api-dev.mjs",
    "dev:processing-worker": "NODE_ENV=development node infrastructure/scripts/run-worker-dev.mjs",
    "dev:ai-service": "tsx apps/ai-service/index.ts",
    "dev:lmstudio-bridge": "tsx infrastructure/scripts/lmstudio-bridge.ts",
    "dev:infra": "bash infrastructure/scripts/docker-compose.sh up -d database cache",
    "docker:boot": "bash infrastructure/scripts/docker-boot.sh",
    "docker:up": "npm run docker:boot",
    "docker:up:core": "bash infrastructure/scripts/docker-boot.sh",
    "docker:up:engine-gateway": "bash infrastructure/scripts/docker-compose.sh --profile ai up -d --build --remove-orphans engine-a-gateway api processing-worker database cache",
    "docker:up:engine-gateway:local-llm": "bash infrastructure/scripts/docker-compose.sh --profile ai --profile local-llm up -d --build --remove-orphans local-llm engine-a-gateway api processing-worker database cache && bash infrastructure/scripts/docker-compose.sh --profile local-llm up local-llm-model-pull",
    "start:docker": "npm run docker:boot",
    "start:docker:gateway": "npm run docker:up:engine-gateway:local-llm",
    "docker:up:ai": "npm run docker:up:engine-gateway",
    "docker:up:ai:local-llm": "npm run docker:up:engine-gateway:local-llm",
    "docker:down": "bash infrastructure/scripts/docker-compose.sh down --remove-orphans",
    "docker:ps": "bash infrastructure/scripts/docker-compose.sh ps",
    "docker:logs": "bash infrastructure/scripts/docker-compose.sh logs --tail=200 api",
    "docker:logs:processing-worker": "bash infrastructure/scripts/docker-compose.sh logs --tail=200 processing-worker",
    "engine:probe": "node infrastructure/scripts/engine-probe.mjs",
    "dev:doctor": "bash infrastructure/scripts/dev-doctor.sh",
    "dev:clean": "bash infrastructure/scripts/dev-clean.sh",
    "dev:boot": "bash infrastructure/scripts/dev-boot.sh",
    "build:client": "node infrastructure/scripts/build-client.mjs",
    "build:ai-service": "node infrastructure/scripts/build-ai-service.mjs",
    "build:processing-worker": "node infrastructure/scripts/build-worker.mjs",
    "build:server": "node infrastructure/scripts/build-server.mjs",
    "quality:ts-nocheck": "bash infrastructure/scripts/check-ts-nocheck-baseline.sh",
    "quality:architecture-boundary": "node --import tsx infrastructure/scripts/check-architecture-boundary.ts",
    "quality:architecture-boundary:baseline": "node --import tsx infrastructure/scripts/check-architecture-boundary.ts --update-baseline",
    "quality:bundle-budget": "node --import tsx infrastructure/scripts/check-bundle-budgets.ts",
    "quality:release": "npm run check && npm run lint && npm run test:security && npm run test:regression:gate && npm run test:business-case:contract && npm run quality:architecture-boundary && npm run validate:production-values && npm run security:route-coverage && npm run security:api-mount-coverage && npm run security:approval-coverage && npm run security:audit && npm run build",
    "quality:release:enterprise": "npm run quality:release && npm run test:e2e:enterprise",
    "build": "npm run build:client && npm run quality:architecture-boundary && npm run quality:bundle-budget && npm run build:server && npm run build:processing-worker",
    "start": "NODE_ENV=production node dist/index.js",
    "start:processing-worker": "NODE_ENV=production node dist/worker/index.js",
    "check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "check:corevia-ai-boundary": "npx -y tsx infrastructure/scripts/check-corevia-ai-boundary.ts",
    "check:platform-ai-boundary": "npx -y tsx infrastructure/scripts/check-platform-ai-boundary.ts",
    "test:security": "vitest run --config vitest.server.config.ts interfaces/config/__tests__/securityRuntime.test.ts interfaces/middleware/__tests__/csrf.middleware.test.ts interfaces/middleware/__tests__/sessionSecurity.middleware.test.ts domains/identity/api/__tests__/sessionSecurity.test.ts",
    "test:regression:gate": "vitest run --config vitest.server.config.ts interfaces/middleware/__tests__/csrf.middleware.test.ts interfaces/middleware/__tests__/sessionSecurity.middleware.test.ts domains/identity/api/__tests__/sessionSecurity.test.ts platform/logging/__tests__/ErrorHandler.test.ts platform/logging/__tests__/RequestContext.test.ts",
    "test:business-case:contract": "vitest run --config vitest.server.config.ts domains/demand/__tests__/financialModel.test.ts",
    "test:regression:top5": "vitest run --config vitest.server.config.ts apps/api/routes/health.test.ts interfaces/middleware/__tests__/csrf.middleware.test.ts interfaces/middleware/__tests__/sessionSecurity.middleware.test.ts domains/identity/api/__tests__/sessionSecurity.test.ts platform/logging/__tests__/ErrorHandler.test.ts",
    "quality:gate": "npm run check && npm run lint && npm run test:security && npm run test:regression:gate && npm run test:business-case:contract",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "security:route-coverage": "node infrastructure/scripts/check-route-permission-coverage.mjs",
    "security:api-mount-coverage": "node infrastructure/scripts/check-api-mount-permission-coverage.mjs",
    "security:approval-coverage": "node infrastructure/scripts/check-approval-permission-coverage.mjs",
    "security:check": "npm run check:corevia-ai-boundary && npm run check:platform-ai-boundary && npm run check && npm run security:route-coverage && npm run security:api-mount-coverage && npm run security:approval-coverage && npm run security:audit",
    "audit:placeholders": "npx -y tsx infrastructure/scripts/audit-brain-placeholders.ts && npx -y tsx infrastructure/scripts/audit-demand-placeholders.ts && npx -y tsx infrastructure/scripts/audit-portfolio-gates-placeholders.ts && npx -y tsx infrastructure/scripts/audit-tender-placeholders.ts",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test": "vitest run --config vitest.server.config.ts",
    "test:watch": "vitest --config vitest.server.config.ts",
    "test:coverage": "vitest run --config vitest.server.config.ts --coverage",
    "test:client": "vitest run --config vitest.client.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:enterprise": "node --import tsx infrastructure/scripts/run-enterprise-e2e.ts",
    "test:perf:smoke": "k6 run infrastructure/scripts/load-test.js",
    "test:perf:baseline": "HEALTH_VUS=25 READINESS_VUS=10 METRICS_RATE=5 LOGIN_TARGET_VUS=30 k6 run infrastructure/scripts/load-test.js",
    "test:perf:300": "k6 run infrastructure/scripts/load-test-300.js",
    "test:all": "npm run test && npm run test:client",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs:api": "tsx infrastructure/scripts/generate-openapi.ts",
    "validate:production-values": "node infrastructure/scripts/validate-production-values.mjs",
    "secret-scan": "bash infrastructure/scripts/pre-commit-secret-scan.sh",
    "prepare": "cp infrastructure/scripts/pre-commit-secret-scan.sh .git/hooks/pre-commit 2>/dev/null && chmod +x .git/hooks/pre-commit 2>/dev/null || true"
  },
